{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "//": {
      "tasks": ["build", "test", "typecheck", "dev", "clean"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
