{
  "name": "@qr-device-flow/storage-redis",
  "version": "0.1.0",
  "description": "Redis storage backend for the QR device flow server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qr-device-flow/core": "workspace:*"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "ioredis": "^5.4.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["qr", "auth", "rfc8628", "device-flow", "redis", "storage"],
  "license": "MIT"
}
